def is_dataset_start(str):
	return re.match('Dataset #[0-9]+ analysis started', str)

def is_dataset_finish(str):
	return re.match('Dataset #[0-9]+ analysis finished.*', str)

def get_starting_datasorted(line):
	starting = line.find('#')
	finishing = line.find('analysis')
	return line[starting+1:finishing-1]


def check_flow1_result(dataset, line):
	line = line.replace('Top Funniest Cities: ', '')
	values = line.split(' ; ')

	if sorted(values) != sorted(EXPECTED_VALUES[0]):
		print(f"There are errors in the Top 10 Funniest Cities flow. Received: {values}")
		return False

	return True


def check_flow2_result(dataset, line):
	line = line.replace('Reviews by Weekday: ', '')
	values = line.split(', ')

	if sorted(values) != sorted(EXPECTED_VALUES[1]):
		print(f"There are errors in the Weekday Histogram flow. Received: {values}")
		return False

	return True


def check_flow3_result(dataset, line):
	line = line.replace('Users with +5 reviews (all with same text): ', '')
	values = line.split(' ; ')

	if sorted(values) != sorted(EXPECTED_VALUES[2]):
		print(f"There are errors in the Bots User flow. Received: {values}")
		return False

	return True
		

def check_flow4_result(dataset, line):
	line = line.replace('Users with +50 reviews: ', '')

	if line != EXPECTED_VALUES[3]:
		print(f"There are errors in the Top Users flow. Received: '{line}'")
		return False

	return True
		

def check_flow5_result(dataset, line):
	line = line.replace('Users with +50 reviews (only 5-stars): ', '')
	values = line.split(' ; ')

	if sorted(values) != sorted(EXPECTED_VALUES[4]):
		print(f"There are errors in the Best Users flow. Received: {values}")
		return False

	return True
		

def check_result(dataset, line):
	if line.startswith('Reviews by Weekday:'):
		return check_flow2_result(dataset, line)
	elif line.startswith('Users with +5 reviews (all with same text):'):
		return check_flow3_result(dataset, line)
	elif line.startswith('Top Funniest Cities:'):
		return check_flow1_result(dataset, line)
	elif line.startswith('Users with +50 reviews:'):
		return check_flow4_result(dataset, line)
	elif line.startswith('Users with +50 reviews (only 5-stars):'):
		return check_flow5_result(dataset, line)
	else:
		print(f'Error! Unexpected result received: {line}')
		return False

def main():
	current_dataset = 0
	results_ok = True
	for line in sys.stdin:
		line = re.sub('.*msg="', '', line)
		line = re.sub('"\n', '', line)

		if is_dataset_start(line):
			current_dataset = get_starting_datasorted(line)
			results_ok = True
			print(f'Starting dataset #{current_dataset}.')
		elif is_dataset_finish(line):
			if results_ok:
				print(f'Dataset #{current_dataset} finished whitout errors.')
			else:
				print(f'Dataset #{current_dataset} with errors.')
		else:
			if not check_result(current_dataset, line):
				results_ok = False

if __name__ == '__main__':
	main()
